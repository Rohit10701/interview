{
  "compilerOptions": {
    "target": "ES2019",
    "module": "CommonJS",
    "rootDir": ".",
    "outDir": "dist",
    "allowJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
        "typeRoots": ["./src/types", "./node_modules/@types"],
    // "strict": true,
    "noImplicitThis": false,
    "skipLibCheck": true
  },
  "include": ["index.ts", "src/**/*", "src/types/**/*.d.ts"]
}
